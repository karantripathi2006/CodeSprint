# ==============================
# Application Settings
# ==============================
APP_NAME=ResuMatch AI
APP_VERSION=1.0.0
DEBUG=true

# ==============================
# API Security
# ==============================
API_KEY=your-secret-api-key-here

# ==============================
# Database (PostgreSQL)
# Falls back to SQLite if not set
# ==============================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resumatch
# DATABASE_URL=sqlite:///./resumatch.db

# ==============================
# Redis (for Celery queue + caching)
# Runs synchronously if not available
# ==============================
REDIS_URL=redis://localhost:6379/0

# ==============================
# ChromaDB Vector Store
# Uses in-memory if path not set
# ==============================
CHROMA_PERSIST_DIR=./chroma_data

# ==============================
# ML Model Settings
# ==============================
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ==============================
# Matching Weights (must sum to 1.0)
# ==============================
SKILL_WEIGHT=0.50
EXPERIENCE_WEIGHT=0.30
EDUCATION_WEIGHT=0.20

# ==============================
# Rate Limiting
# ==============================
RATE_LIMIT=30/minute
